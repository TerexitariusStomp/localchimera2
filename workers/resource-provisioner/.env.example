# EVM
RPC_URL=https://sepolia.gateway.request.network/
PRIVATE_KEY=0x
CHAIN_ID=11155111

# Cloudflare KV
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=

# Worker
POLL_INTERVAL_MS=30000

# Resource endpoints (optional)
BTFS_API_URL=http://localhost:5001
MYSTERIUM_API_URL=http://localhost:4050
ANYONE_API_URL=http://localhost:9001
BTT_AI_API_URL=http://localhost:8000
AKASH_API_URL=https://console-api.akash.network/v1
AKASH_SDL_FILE=/home/user/CascadeProjects/localchimera/infra/akash-fhe/deploy.yml
Casper_API_URL=https://rpc.mainnet.casper.network/rpc

# Storj (used when STORAGE_PROVIDER=storj)
STORJ_BUCKET=chimera-fallback
STORJ_GATEWAY_URL=https://gateway.storjshare.io
STORJ_UPLINK_BINARY=uplink

# Golem
GOLEM_API_KEY=try_golem
GOLEM_PAYMENT_NETWORK=polygon

# Casper escrow fallback (optional)
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
# Either paste the PEM directly, or provide a path to a PEM file
CASPER_PROVIDER_KEY_PEM=
CASPER_PROVIDER_KEY_PEM_PATH=
CASPER_ESCROW_VAULT=b8e8b7e087ec4ad7afcdc30460d39d5b6a8249875cd1e2da0716b89d710fda40
CASPER_COMPUTE_REGISTRY=bb3044c3bbefc669c4c7c41a10cb645f5e160bfab62883b34e08d0a99b981d07

# Botchain escrow fallback (optional)
BOTCHAIN_RPC_URL=https://rpc.bohr.life
BOTCHAIN_PRIVATE_KEY=0x
BOTCHAIN_ESCROW_VAULT=0x82bb0e1f4cde3e1285fcd80464680e97833c8d54
BOTCHAIN_COMPUTE_REGISTRY=0x3737485f189d92a1455ed841fee4e8cc8a353e85
# Set after deploying contracts/ChimeraCoordinator.sol
BOTCHAIN_COORDINATOR_ADDRESS=
# Set after deploying contracts/ChimeraBridgeDispatcher.sol
BOTCHAIN_BRIDGE_DISPATCHER_ADDRESS=

# Volunteer coordinator server (push dispatch)
COORDINATOR_PORT=8080
COORDINATOR_AUTH_TOKEN=development-token

# Protocol payout address used by all external miner providers (Storj, Anyone, Mysterium, BTT AI, Golem).
# No private key is stored in the SDK or worker; this is the public address that receives network rewards.
CHIMERA_PROTOCOL_PAYOUT_ADDRESS=0x7eB4A545F875FC1Da252661d31a3e28e67bf723f

# Fallback dispatcher tuning
# Set to true to force GPU tasks to Akash (Golem is CPU-only).
FALLBACK_REQUIRES_GPU=false
VOLUNTEER_DISPATCH_MS=10000
VOLUNTEER_DISPATCH_RETRIES=2
VOLUNTEER_WAIT_MS=45000
FALLBACK_POLL_INTERVAL_MS=15000
MAX_PENDING_AGE_MS=300000
FALLBACK_RECIPIENT=
# Inference provider: btt-ai (default) or akash
INFERENCE_PROVIDER=btt-ai
FALLBACK_INFERENCE_TOKENS=512
FALLBACK_INFERENCE_MODEL=llama-3.2-1b
# Compute provider: golem (default) or akash
COMPUTE_PROVIDER=golem
FALLBACK_COMPUTE_HOURS=1
FALLBACK_GOLEM_IMAGE_TAG=golem/alpine:latest
# Storage provider: storj (default) or btfs
STORAGE_PROVIDER=storj
FALLBACK_STORAGE_GB=1
# Bandwidth provider: mysterium (default) or anyone
BANDWIDTH_PROVIDER=mysterium
FALLBACK_BANDWIDTH_HOURS=1
FALLBACK_BANDWIDTH_GB=1

# Production infrastructure
EDGE_NETWORK_API_KEY=
EDGE_NETWORK_API_URL=https://api.edge.network/
STREAMR_NODE_PRIVATE_KEY=
STREAMR_STREAM_ID=
STREAMR_API_URL=https://streamr.network/api
NAMESILO_API_KEY=
NAMESILO_CONTACT_PROFILE=default
