{
  "name": "localchimera-site",
  "version": "1.0.0",
  "description": "Cloudflare Pages static site + React console for Chimera",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev . --compatibility-date=2024-12-01",
    "copy-browser-sdk": "node scripts/copy-browser-sdk.js",
    "build-inference-frontend": "cd ../website/inference-frontend && npm run build",
    "build-docs": "vitepress build docs",
    "sync-provider-locations": "node scripts/sync-provider-locations.js",
    "predeploy": "npm run copy-browser-sdk && npm run build-inference-frontend && npm run build-docs && npm run sync-provider-locations",
    "deploy": "wrangler pages deploy . --project-name new-localchimera",
    "test:e2e": "playwright test e2e/",
    "test:backend-jwt": "node test-backend-jwt.js",
    "secret": "wrangler pages secret put NAMESILO_KEY"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "ethers": "^6.17.0"
  },
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@playwright/test": "^1.61.1",
    "@remix-run/cloudflare": "^2.17.5",
    "@remix-run/cloudflare-pages": "^2.17.5",
    "bs58": "^6.0.0",
    "jose": "^6.2.3",
    "playwright": "^1.61.1",
    "vitepress": "^1.3.0",
    "wrangler": "^3.0.0"
  }
}
