# Relayer testnet environment variables
# Copy this to upstream/fhevm/relayer/.env (which is gitignored) and fill in the values.

# Private key of the funded wallet on the Zama Gateway testnet.
APP_GATEWAY__TX_ENGINE__SIGNER__PRIVATE_KEY=0x...

# PostgreSQL connection URL (default matches the Docker Compose setup in upstream/fhevm/relayer/dev/docker-compose.yaml).
APP_STORAGE__SQL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relayer_db
