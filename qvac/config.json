        "signers": 3
      },
      "bittensor": {
        "enabled": true,
        "protocol": "substrate-multisig",
        "address": "5QVACProtocolMultisigBittensorXYZ123",
        "threshold": 2,
        "signers": 3
      },
      "solana": {
        "enabled": true,
        "protocol": "spl-multisig",
        "address": "4R5d695FM5AiVjTkbadrjU4wr9ayK7ajeMdqgLd9muQA",
        "threshold": 2,
        "signers": 3
      }
    }
