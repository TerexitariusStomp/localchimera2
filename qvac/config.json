  "miners": {
    "enabled": true,
    "parallelMode": true,
    "priority": ["cortensor", "chutes", "fortytwo", "earnidle", "routstr"],
    "switchInterval": 60000,
    "cortensor": {
      "enabled": true,
      "config": {
        "network": "arbitrum-testnet",
        "walletAddress": "",
        "protocolAddress": "0xChimeraProtocolCortensorMultisig0001",
        "cortensorHome": "~/.cortensor",
        "envFile": "~/.cortensor/.env",
        "cortensordPath": "",
        "autoFundSweep": true
      }
    },
    "chutes": {
      "enabled": true,
      "config": {
        "network": "bittensor",
        "protocolAddress": "5QVACProtocolMultisigBittensorXYZ123",
        "multisigType": "substrate",
        "multisigThreshold": "2-of-3",
        "requiresK8s": true,
        "stackCompatible": false,
        "compatibilityMode": true,
        "autoFundSweep": true
      }
    },
    "fortytwo": {
      "enabled": true,
      "config": {
        "network": "evm",
        "protocolAddress": "0xChimeraProtocolFortytwoMultisig0001",
        "autoFundSweep": true
      }
