    "earnidle": {
      "enabled": true,
      "config": {
        "network": "solana",
        "walletAddress": "4R5d695FM5AiVjTkbadrjU4wr9ayK7ajeMdqgLd9muQA",
        "protocolAddress": "4R5d695FM5AiVjTkbadrjU4wr9ayK7ajeMdqgLd9muQA",
