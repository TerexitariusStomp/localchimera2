        "model": "llama-3.2-1b-instruct",
        "gpuAvailable": false,
        "pollInterval": 30000,
        "apiBase": "https://api.earnidle.com",
        "autoFundSweep": true
      }
    },
    "routstr": {
      "enabled": true,
      "config": {
        "network": "nostr",
        "platform": "https://beta.platform.routstr.com/",
        "protocolAddress": "npub1qvacprotocolmultisigabc123xyz789",
        "walletType": "nip-60",
        "multisigType": "cashu-p2sh",
        "multisigThreshold": "2-of-3",
        "autoFundSweep": true
      }
