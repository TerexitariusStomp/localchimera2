{
  "node": {
    "id": "02b8357bdd44fbb6bd12f2b07cc993ee",
    "name": "Chimera Mining Node",
    "version": "1.0.0"
  },
  "inference": {
    "enabled": true,
    "qvac": {
      "endpoint": "local",
      "models": ["llama-3.2-1b-instruct"],
      "modelConst": "LLAMA_3_2_1B_INST_Q4_0",
      "maxConcurrent": 4
