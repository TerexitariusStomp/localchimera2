{
  "expo": {
    "name": "Chimera",
    "slug": "chimera-mobile",
    "version": "1.0.22",
    "orientation": "portrait",
    "icon": "./assets/splash.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.chimera.mobile",
      "buildNumber": "1.0.22"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/splash.png",
        "backgroundColor": "#0a0a14"
      },
      "package": "io.chimera.mobile",
      "versionCode": 10022,
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "@qvac/sdk/expo-plugin"
    ],
    "extra": {
      "qvac": {
        "modelsDir": "models",
        "defaultModel": "LLAMA_3_2_1B_INST_Q4_0"
      }
    }
  }
}
