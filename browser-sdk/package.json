{
  "name": "@localchimera/browser-sdk",
  "version": "1.0.5",
  "description": "Chimera Browser SDK — run a tasker network node entirely in the browser. No download required.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser-node": {
      "import": "./dist/browser-node.js",
      "default": "./dist/browser-node.js",
      "types": "./dist/browser-node.d.ts"
    },
    "./casper-client": {
      "import": "./dist/casper-client.js",
      "default": "./dist/casper-client.js",
      "types": "./dist/casper-client.d.ts"
    },
    "./network-adapters": {
      "import": "./dist/network-adapters.js",
      "default": "./dist/network-adapters.js",
      "types": "./dist/network-adapters.d.ts"
    },
    "./roma-router": {
      "import": "./dist/roma-router.js",
      "default": "./dist/roma-router.js",
      "types": "./dist/roma-router.d.ts"
    },
    "./task-types": {
      "import": "./dist/task-types.js",
      "default": "./dist/task-types.js",
      "types": "./dist/task-types.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "default": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --format=esm --outfile=dist/bundle.js --platform=browser --target=es2022 --inject:buffer-shim.js --external:@mlc-ai/web-llm --external:@huggingface/transformers --external:helia --external:@helia/ipfs --external:@helia/unixfs --external:@wasmer/sdk --external:multiformats",
    "prepublishOnly": "npm run build",
    "test": "echo 'no tests yet' && exit 0"
  },
  "keywords": [
    "chimera",
    "browser",
    "node",
    "mining",
    "inference",
    "casper",
    "webgpu",
    "ipfs",
    "wasi",
    "webrtc",
    "cortensor",
    "fortytwo"
  ],
  "author": "Chimera",
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@toruslabs/tss-dkls-lib": "^4.1.0",
    "@web3auth/auth": "^11.8.1",
    "@web3auth/base": "^9.7.0",
    "@web3auth/ethereum-provider": "^9.7.0",
    "@web3auth/modal": "^9.7.0",
    "@web3auth/mpc-core-kit": "^3.5.0",
    "@web3auth/single-factor-auth": "^9.2.0",
    "casper-js-sdk": "^5.0.12",
    "ethers": "^6.17.0"
  },
  "peerDependencies": {
    "@helia/ipfs": ">=4.0.0",
    "@helia/unixfs": ">=4.0.0",
    "@huggingface/transformers": ">=3.0.0",
    "@mlc-ai/web-llm": ">=0.2.0",
    "@wasmer/sdk": ">=0.10.0",
    "helia": ">=4.0.0",
    "multiformats": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "@mlc-ai/web-llm": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "helia": {
      "optional": true
    },
    "@helia/ipfs": {
      "optional": true
    },
    "@helia/unixfs": {
      "optional": true
    },
    "@wasmer/sdk": {
      "optional": true
    },
    "multiformats": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
