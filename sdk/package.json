{
  "name": "@localchimera/sdk",
  "version": "1.0.6",
  "description": "Chimera SDK — tasking network provider SDK. Integrate decentralized compute, storage, bandwidth, and inference mining into your app.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./useChimera": {
      "import": "./dist/useChimera.js",
      "default": "./dist/useChimera.js",
      "types": "./dist/useChimera.d.ts"
    },
    "./ChimeraSDK": {
      "import": "./dist/ChimeraSDK.js",
      "default": "./dist/ChimeraSDK.js",
      "types": "./dist/ChimeraSDK.d.ts"
    },
    "./miners/*": {
      "import": "./dist/miners/*.js",
      "default": "./dist/miners/*.js",
      "types": "./dist/miners/*.d.ts"
    },
    "./storage/*": {
      "import": "./dist/storage/*.js",
      "default": "./dist/storage/*.js",
      "types": "./dist/storage/*.d.ts"
    },
    "./runtime/*": {
      "import": "./dist/runtime/*.js",
      "default": "./dist/runtime/*.js",
      "types": "./dist/runtime/*.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "chimera",
    "mining",
    "inference",
    "ai",
    "p2p",
    "depin",
    "golem",
    "mysterium",
    "anyone-protocol",
    "btfs",
    "btt-ai",
    "casper"
  ],
  "author": "Chimera",
  "license": "MIT",
  "peerDependencies": {
    "@privy-io/react-auth": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@localchimera/browser-sdk": {
      "optional": true
    },
    "system-resource-monitor": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
